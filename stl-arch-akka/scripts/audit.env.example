# Copy to your repo as scripts/audit.env and adjust for the service.
# Requires: bash, ripgrep (rg), awk, find, grep.

# --- Required: impl module and main package path ---
AUDIT_IMPL_MODULE=stey-crs-impl
AUDIT_IMPL_PKG_PATH=com/stey/crs/impl

# --- Tier boundary patterns (ripgrep regex) ---
AUDIT_GRPC_IMPORT='com\.stey\.crs\.api\.grpc'
AUDIT_ENTITY_IMPORT='com\.stey\.crs\.impl\.entity'
# Command/event ADT definitions must not reference these; handlers may.
AUDIT_STATE_ADT_PATTERN='ConfigState\.|ReservationState\.|RateState\.|InventoryState\.|AvailabilityState\.|RoomStatusState\.'
# Internal tier must not import aggregate.state (write-path ADTs on object *Internal).
AUDIT_INTERNAL_STATE_IMPORT='com\.stey\.crs\.impl\.aggregate\.state'

# --- Optional gates (leave empty to skip or use generic default) ---
AUDIT_INTERNAL_FLAT_PARAM_PATTERN='request: (Config|Reservation|System)Internal\.'
AUDIT_SERIALIZATION_SPEC_DIR=stey-crs-impl/src/test/scala/com/stey/crs/impl/serialization

# SteyCrs-specific colocation checks (space-separated, relative to AUDIT_MAIN):
AUDIT_FORBIDDEN_REL_PATHS='aggregate/CommandJacksonStringBridge.scala aggregate/state/config/ProjectConfigJson.scala'
# Only these basenames allowed under aggregate/state/<subdir>/:
AUDIT_STATE_SUBDIR_ALLOWLIST='reservation:ReservationState.scala,HasReservation.scala'
