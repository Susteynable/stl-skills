[
  {
    "key": "ctrl+shift+j",
    "command": "editor.action.joinLines",
    "when": "editorTextFocus && !editorReadonly",
    "_stl_ide_toolbox": "editor.join-lines"
  },
  {
    "key": "ctrl+g",
    "command": "editor.action.addSelectionToNextFindMatch",
    "when": "editorFocus",
    "_stl_ide_toolbox": "editor.add-selection-to-next-find-match"
  },
  {
    "key": "ctrl+g",
    "command": "-workbench.action.gotoLine",
    "_stl_ide_toolbox": "workbench.unbind-goto-line"
  },
  {
    "key": "ctrl+cmd+g",
    "command": "editor.action.selectHighlights",
    "when": "editorFocus",
    "_stl_ide_toolbox": "editor.select-all-occurrences"
  },
  {
    "key": "alt+q",
    "command": "runCommands",
    "args": {
      "commands": [
        "workbench.action.terminal.focus",
        {
          "command": "workbench.action.terminal.sendSequence",
          "args": {
            "text": "\"/Users/liangliao/Applications/IntelliJ IDEA.app/Contents/MacOS/idea\" --line ${lineNumber} \"${file}\"\r"
          }
        },
        "workbench.action.closePanel",
        "workbench.action.focusActiveEditorGroup"
      ]
    },
    "when": "editorTextFocus",
    "_stl_ide_toolbox": "editor.open-in-intellij"
  },
  {
    "key": "f2",
    "command": "renameFile",
    "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus",
    "_stl_ide_toolbox": "explorer.rename-f2"
  },
  {
    "key": "enter",
    "command": "-renameFile",
    "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus",
    "_stl_ide_toolbox": "explorer.unbind-enter-rename"
  },
  {
    "key": "alt+cmd+s",
    "command": "workbench.action.toggleUnifiedSidebarFromKeyboard",
    "when": "!isAuxiliaryWindowFocusedContext",
    "_stl_ide_toolbox": "workbench.toggle-sidebar"
  },
  {
    "key": "cmd+i",
    "command": "composerMode.agent",
    "_stl_ide_toolbox": "cursor.agent-composer"
  },
  {
    "key": "cmd+y",
    "command": "-aichat.newfollowupaction",
    "_stl_ide_toolbox": "cursor.unbind-followup"
  },
  {
    "key": "f1",
    "command": "-workbench.action.showCommands",
    "_stl_ide_toolbox": "workbench.unbind-f1-command-palette"
  },
  {
    "key": "f1",
    "command": "editor.action.revealDefinition",
    "when": "editorHasDefinitionProvider && editorTextFocus && !isInEmbeddedEditor",
    "_stl_ide_toolbox": "editor.goto-definition-f1"
  },
  {
    "key": "f12",
    "command": "-editor.action.revealDefinition",
    "_stl_ide_toolbox": "editor.unbind-f12-goto-definition"
  },
  {
    "key": "alt+f1",
    "command": "editor.action.peekDefinition",
    "when": "editorHasDefinitionProvider && editorTextFocus && !isInEmbeddedEditor",
    "_stl_ide_toolbox": "editor.peek-definition-alt-f1"
  },
  {
    "key": "alt+f12",
    "command": "-editor.action.peekDefinition",
    "_stl_ide_toolbox": "editor.unbind-alt-f12-peek-definition"
  },
  {
    "key": "cmd+f1",
    "command": "editor.action.goToImplementation",
    "when": "editorHasImplementationProvider && editorTextFocus && !isInEmbeddedEditor",
    "_stl_ide_toolbox": "editor.goto-implementation-cmd-f1"
  },
  {
    "key": "cmd+f12",
    "command": "-editor.action.goToImplementation",
    "_stl_ide_toolbox": "editor.unbind-cmd-f12-goto-implementation"
  },
  {
    "key": "shift+f1",
    "command": "editor.action.goToReferences",
    "when": "editorHasReferenceProvider && editorTextFocus && !isInEmbeddedEditor",
    "_stl_ide_toolbox": "editor.goto-references-shift-f1"
  },
  {
    "key": "shift+f12",
    "command": "-editor.action.goToReferences",
    "_stl_ide_toolbox": "editor.unbind-shift-f12-goto-references"
  },
  {
    "key": "shift+alt+f1",
    "command": "references-view.findReferences",
    "when": "editorHasReferenceProvider",
    "_stl_ide_toolbox": "editor.find-references-view-shift-alt-f1"
  },
  {
    "key": "shift+alt+f12",
    "command": "-references-view.findReferences",
    "_stl_ide_toolbox": "editor.unbind-shift-alt-f12-find-references"
  }
]
